# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Visualization — set as Supabase secrets via:
#   supabase secrets set GEMINI_API_KEY=your-key
#   supabase secrets set HF_API_KEY=your-key
# At least one is required for AI mode in the Visualizer.
# GEMINI_API_KEY — Google AI Studio (primary, fastest)
# HF_API_KEY — HuggingFace (fallback, uses FLUX.1 Kontext via fal-ai)
